@model IEnumerable<TechMoveGLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Requests</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Service Request</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Contract</th>
            <th>Client</th>
            <th>Description</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    Contract #@item.ContractId
                </td>

                <td>
                    @item.Contract?.Client?.Name
                </td>

                <td>
                    @item.Description
                </td>

                <td>
                    @item.CostInUSD.ToString("0.00")
                </td>

                <td>
                    @item.CostInZAR.ToString("0.00")
                </td>

                <td>
                    <span class="badge
                        @(item.Status == "Completed" ? "bg-success" :
                                                item.Status == "Pending" ? "bg-warning" :
                                                "bg-secondary")">
                    @item.Status
                </span>
            </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-info btn-sm">
                        Details
                    </a>

                    <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
                }
    </tbody>
</table>