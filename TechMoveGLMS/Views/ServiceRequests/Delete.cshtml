@model TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1>Delete Service Request</h1>

<h3>Are you sure you want to delete this service request?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Contract</dt>
        <dd class="col-sm-9">@Model.ContractId</dd>

        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Cost (USD)</dt>
        <dd class="col-sm-9">@Model.CostInUSD</dd>

        <dt class="col-sm-3">Cost (ZAR)</dt>
        <dd class="col-sm-9">@Model.CostInZAR</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ServiceRequestId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>