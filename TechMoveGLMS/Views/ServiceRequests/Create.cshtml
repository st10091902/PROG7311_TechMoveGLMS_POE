@model TechMoveGLMS.ViewModels.ServiceRequestFormViewModel

@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create Service Request</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="control-label"></label>
                <select asp-for="ContractId" asp-items="Model.Contracts" class="form-control">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CostInUSD" class="control-label"></label>
                <input asp-for="CostInUSD" class="form-control" />
                <span asp-validation-for="CostInUSD" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Cost in ZAR</label>
                <input class="form-control" value="@(Model.CostInZAR?.ToString("0.00") ?? "Will be calculated on save")" readonly />
                <span class="text-muted">This value will be recalculated automatically by the API when you save.</span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}