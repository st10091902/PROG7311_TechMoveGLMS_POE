@model TechMoveGLMS.ViewModels.ContractFormViewModel

@{
    ViewData["Title"] = "Edit Contract";
}

<h1>Edit Contract</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.ContractId" enctype="multipart/form-data">
            <input type="hidden" asp-for="ContractId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ClientId" class="control-label"></label>
                <select asp-for="ClientId" asp-items="Model.Clients" class="form-control">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<TechMoveGLMS.Models.ContractStatus>()" class="form-control"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <input asp-for="ServiceLevel" class="form-control" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SignedAgreementFile" class="control-label"></label>
                <input asp-for="SignedAgreementFile" class="form-control" type="file" accept=".pdf" />
                <span asp-validation-for="SignedAgreementFile" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ExistingFilePath))
            {
                <div class="mb-3">
                    <span>Current File:</span>
                    <a asp-action="DownloadAgreement" asp-route-id="@Model.ContractId">Download Current PDF</a>
                </div>
            }

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}