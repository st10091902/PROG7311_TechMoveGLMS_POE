@model TechMoveGLMS.ViewModels.ContractFilterViewModel

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Contract</a>
</p>

<hr />

<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="StartDateFrom" class="form-label"></label>
        <input asp-for="StartDateFrom" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="EndDateTo" class="form-label"></label>
        <input asp-for="EndDateTo" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<TechMoveGLMS.Models.ContractStatus>()" class="form-control">
            <option value="">-- All Statuses --</option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-success me-2">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Contracts)
        {
            <tr>
                <td>@item.Client?.Name</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@item.ServiceLevel</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.SignedAgreementFilePath))
                    {
                        <a asp-action="DownloadAgreement" asp-route-id="@item.ContractId" class="btn btn-success btn-sm">Download PDF</a>
                    }
                    else
                    {
                        <span>No File</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ContractId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ContractId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ContractId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>