  "components": {
    "schemas": {
      "Client": {
        "required": [
          "contactDetails",
          "name",
          "region"
        ],
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "contactDetails": {
            "maxLength": 150,
            "minLength": 0,
            "type": "string"
          },
          "region": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "contracts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contract"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Contract": {
        "required": [
          "clientId",
          "endDate",
          "serviceLevel",
          "startDate",
          "status"
        ],
        "type": "object",
        "properties": {
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "client": {
            "$ref": "#/components/schemas/Client"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "$ref": "#/components/schemas/ContractStatus"
          },
          "serviceLevel": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "signedAgreementFileName": {
            "type": "string",
            "nullable": true
          },
          "signedAgreementFilePath": {
            "type": "string",
            "nullable": true
          },
          "serviceRequests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServiceRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ContractStatus": {
        "enum": [
          0,
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "ServiceRequest": {
        "required": [
          "contractId",
          "costInUSD",
          "costInZAR",
          "description",
          "status"
        ],
        "type": "object",
        "properties": {
          "serviceRequestId": {
            "type": "integer",
            "format": "int32"
          },
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "contract": {
            "$ref": "#/components/schemas/Contract"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          },
          "costInUSD": {
            "type": "number",
            "format": "double"
          },
          "costInZAR": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
